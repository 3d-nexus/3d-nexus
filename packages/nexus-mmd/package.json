{
  "name": "@3d-nexus/mmd",
  "version": "0.1.0",
  "description": "PMX, PMD, and VMD import/export support for 3d-nexus.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "3d",
    "nexus",
    "mmd",
    "pmx",
    "pmd",
    "vmd"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3d-nexus/3d-nexus.git",
    "directory": "packages/nexus-mmd"
  },
  "homepage": "https://github.com/3d-nexus/3d-nexus#readme",
  "bugs": {
    "url": "https://github.com/3d-nexus/3d-nexus/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "@3d-nexus/core": "workspace:*"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  }
}
