{
  "name": "@3d-nexus/core",
  "version": "0.1.0",
  "description": "Core IR, math utilities, and compatibility types for 3d-nexus.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "3d",
    "nexus",
    "converter",
    "intermediate-representation",
    "types",
    "math"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3d-nexus/3d-nexus.git",
    "directory": "packages/nexus-core"
  },
  "homepage": "https://github.com/3d-nexus/3d-nexus#readme",
  "bugs": {
    "url": "https://github.com/3d-nexus/3d-nexus/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests"
  }
}
